---
interface Props {
  slug: string;
  title: { en: string; zh: string };
  year: number;
  material: string;
  image: string;
  tags: string[];
  type: 'original' | 'copy';
}

const { slug, title, year, material, image, tags, type } = Astro.props;
---

<a href={`/work/${slug}`} class="work-card" data-tags={tags.join(',')} data-year={year} data-type={type}>
  <div class="card-image">
    <img src={image} alt={title.en} loading="lazy" />
  </div>
  <div class="card-info">
    <h3 class="card-title" data-en={title.en} data-zh={title.zh}>{title.en}</h3>
    <p class="card-meta">{year} &middot; {material}</p>
  </div>
</a>

<style>
  .work-card {
    display: block;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    transition: transform var(--transition);
  }

  .work-card:hover {
    transform: translateY(-4px);
  }

  .work-card:hover .card-image img {
    transform: scale(1.03);
  }

  .card-image {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background-color: var(--color-bg-alt);
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .card-info {
    padding: var(--space-md) 0;
  }

  .card-title {
    font-size: 1.05rem;
    font-weight: 600;
    margin-bottom: var(--space-xs);
  }

  .card-meta {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    letter-spacing: 0.03em;
  }
</style>
