---
import fs from 'node:fs';
import path from 'node:path';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const all = await getCollection('series', ({ data }) => !data.draft);
  return all.map(s => ({ params: { slug: s.id }, props: { series: s } }));
}

const { series } = Astro.props;
const { title, description } = series.data;

// Auto-discover images: just drop files into public/images/series/<slug>/
const dir = path.resolve('./public/images/series', series.id);
let images: string[] = [];
if (fs.existsSync(dir)) {
  images = fs.readdirSync(dir)
    .filter(f => /\.(png|jpe?g|webp|gif|avif)$/i.test(f))
    .sort()
    .map(f => `/images/series/${series.id}/${f}`);
}
---

<BaseLayout title={title.en} description={description.en}>
  <section class="section">
    <div class="container">
      <a href="/series" class="back-link" data-en="← All series" data-zh="← 返回系列">← All series</a>

      <header class="series-header">
        <h1 class="page-title" data-en={title.en} data-zh={title.zh}>{title.en}</h1>
        <p class="series-desc" data-en={description.en} data-zh={description.zh}>{description.en}</p>
      </header>

      {images.length === 0 ? (
        <p class="empty" data-en="No images yet — drop files into public/images/series/{series.id}/" data-zh="暂无图片——请将文件放入 public/images/series/{series.id}/">
          No images yet.
        </p>
      ) : (
        <div class="masonry">
          {images.map((src, i) => (
            <figure class="masonry-item">
              <img src={src} alt={`${title.en} ${i + 1}`} loading={i < 2 ? 'eager' : 'lazy'} />
            </figure>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .back-link {
    display: inline-block;
    margin-bottom: var(--space-lg);
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }
  .back-link:hover {
    color: var(--color-primary);
  }
  .series-header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }
  .page-title {
    margin-bottom: var(--space-md);
  }
  .page-title::after {
    content: '';
    display: block;
    width: 40px;
    height: 2px;
    background-color: var(--color-accent);
    margin: var(--space-md) auto 0;
  }
  .series-desc {
    color: var(--color-text-muted);
    max-width: 640px;
    margin: 0 auto;
    line-height: 1.8;
  }

  /* CSS multi-column masonry — packs images vertically with no blank space */
  .masonry {
    column-count: 3;
    column-gap: var(--space-lg);
  }
  .masonry-item {
    margin: 0 0 var(--space-lg) 0;
    break-inside: avoid;
    background-color: var(--color-bg-alt);
    overflow: hidden;
  }
  .masonry-item img {
    width: 100%;
    height: auto;
    display: block;
  }

  .empty {
    text-align: center;
    color: var(--color-text-muted);
    font-style: italic;
    padding: var(--space-xl) 0;
  }

  @media (max-width: 1024px) {
    .masonry { column-count: 2; }
  }
  @media (max-width: 600px) {
    .masonry { column-count: 1; }
  }
</style>
