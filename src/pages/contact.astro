---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Get in touch with sculptor Zhao Kun for inquiries, commissions, or general questions.">
  <section class="section">
    <div class="container">
      <h1 class="page-title" data-en="Contact" data-zh="联系方式">Contact</h1>

      <div class="contact-layout">
        <!-- Form -->
        <form class="contact-form" id="contactForm" action="#" method="POST">
          <div class="form-group">
            <label for="name" data-en="Name" data-zh="姓名">Name</label>
            <input type="text" id="name" name="name" required />
          </div>

          <div class="form-group">
            <label for="email" data-en="Email" data-zh="邮箱">Email</label>
            <input type="email" id="email" name="email" required />
          </div>

          <div class="form-group">
            <label for="subject" data-en="Subject" data-zh="主题">Subject</label>
            <select id="subject" name="subject">
              <option value="inquiry" data-en="Inquiry" data-zh="咨询">Inquiry</option>
              <option value="commission" data-en="Commission" data-zh="委托创作">Commission</option>
              <option value="general" data-en="General" data-zh="一般咨询">General</option>
            </select>
          </div>

          <div class="form-group">
            <label for="message" data-en="Message" data-zh="留言">Message</label>
            <textarea id="message" name="message" rows="6" required></textarea>
          </div>

          <button type="submit" class="btn btn-primary" data-en="Send Message" data-zh="发送消息">Send Message</button>
        </form>

        <!-- Contact Info -->
        <aside class="contact-info">
          <h2 data-en="Get in Touch" data-zh="联系我们">Get in Touch</h2>
          <p class="contact-intro" data-en="For inquiries about available works, commissions, or exhibition opportunities, please reach out using the form or contact details below." data-zh="如需咨询可售作品、委托创作或展览合作，请通过表单或以下联系方式与我们联系。">
            For inquiries about available works, commissions, or exhibition opportunities, please reach out using the form or contact details below.
          </p>

          <div class="info-list">
            <div class="info-item">
              <span class="info-label" data-en="Email" data-zh="邮箱">Email</span>
              <a href="mailto:studio@zhaokun.art">studio@zhaokun.art</a>
            </div>
            <div class="info-item">
              <span class="info-label" data-en="Location" data-zh="地点">Location</span>
              <span data-en="Beijing, China" data-zh="中国·北京">Beijing, China</span>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-title {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .page-title::after {
    content: '';
    display: block;
    width: 40px;
    height: 2px;
    background-color: var(--color-accent);
    margin: var(--space-md) auto 0;
  }

  .contact-layout {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: var(--space-xl);
    align-items: start;
  }

  .form-group {
    margin-bottom: var(--space-md);
  }

  .form-group label {
    display: block;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-xs);
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    font-family: var(--font-body);
    font-size: 0.95rem;
    padding: 0.75rem;
    border: 1px solid var(--color-border);
    background-color: var(--color-bg);
    color: var(--color-text);
    border-radius: 2px;
    transition: border-color var(--transition);
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-primary);
  }

  .form-group textarea {
    resize: vertical;
  }

  .contact-info {
    padding: var(--space-lg);
    background-color: var(--color-bg-alt);
  }

  .contact-info h2 {
    font-size: 1.3rem;
    margin-bottom: var(--space-md);
  }

  .contact-intro {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.7;
    margin-bottom: var(--space-lg);
  }

  .info-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .info-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .info-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }

  .info-item a {
    color: var(--color-primary);
  }

  @media (max-width: 768px) {
    .contact-layout {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  document.getElementById('contactForm')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const lang = localStorage.getItem('lang') || 'en';
    const msg = lang === 'zh' ? '感谢您的留言！我们会尽快回复。' : 'Thank you for your message! We will get back to you soon.';
    alert(msg);
    (e.target as HTMLFormElement).reset();
  });
</script>
