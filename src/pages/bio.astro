---

<BaseLayout title="Biography" description="Biography of ceramic sculptor Zhao Kun — Jiangxi Provincial Ceramic Art Master, Jingdezhen Intangible Cultural Heritage Inheritor.">
  <section class="section">
    <div class="container bio-layout">
      <!-- Portrait -->
      <div class="bio-portrait">
        <img src="/images/bio/portrait.png" alt="Zhao Kun" />
      </div>

      <!-- Biography -->
      <div class="bio-content">
        <h1 class="page-title" data-en="Zhao Kun" data-zh="赵坤">Zhao Kun</h1>
        <p class="bio-tagline" data-en="Ceramic Sculptor · Jingdezhen" data-zh="陶瓷雕塑家 · 景德镇">Ceramic Sculptor · Jingdezhen</p>

        <div class="bio-text">
          <p data-en="Zhao Kun, born in 1968 in Huainan, Anhui Province, graduated from the Jingdezhen Ceramic Institute. She is currently a Jiangxi Provincial Ceramic Art Master, a Jingdezhen Intangible Cultural Heritage Inheritor, and one of Jingdezhen's '3+1+X' designated talents." data-zh="赵坤，1968年生于安徽淮南，毕业于景德镇陶瓷学院。现为江西省陶瓷艺术大师、景德镇市非遗传人、景德镇市3+1+X人才。">
            Zhao Kun, born in 1968 in Huainan, Anhui Province, graduated from the Jingdezhen Ceramic Institute. She is currently a Jiangxi Provincial Ceramic Art Master, a Jingdezhen Intangible Cultural Heritage Inheritor, and one of Jingdezhen's "3+1+X" designated talents.
          </p>
          <p data-en="She is a member of the China Arts & Crafts Society, a member of the Jiangxi Artists Association, an individual director of the Zhongshan Painting Academy of the Revolutionary Committee of the Chinese Kuomintang (RCCK) Central Committee, vice-president of the Jiangxi RCCK Zhongshan Painting Academy, a director of the Jingdezhen Artists Association, a guest professor at Jingdezhen Ceramic University, the Ceramic Art Research Institute of Communication University of China, and Shanghai Institute of Visual Arts, and the founder of Zui Ni Zhai Ceramic Art Studio." data-zh="系中国工艺美术学会会员、江西省美术家协会会员、民革中央中山画院个人理事、江西省民革中山画院副院长、景德镇市美术家协会理事、景德镇陶瓷大学客座教授、中国传媒大学陶瓷艺术研究所客座教授、上海视觉艺术学院客座教授、醉泥斋陶艺工作室主理人等。">
            She is a member of the China Arts & Crafts Society, a member of the Jiangxi Artists Association, an individual director of the Zhongshan Painting Academy of the Revolutionary Committee of the Chinese Kuomintang (RCCK) Central Committee, vice-president of the Jiangxi RCCK Zhongshan Painting Academy, a director of the Jingdezhen Artists Association, a guest professor at Jingdezhen Ceramic University, the Ceramic Art Research Institute of Communication University of China, and Shanghai Institute of Visual Arts, and the founder of Zui Ni Zhai Ceramic Art Studio.
          </p>
          <p data-en="Her works mostly take animals as their subject, combining a wide range of clay bodies and techniques to render natural, innocent, and earthy forms in the freehand spirit of Chinese xieyi painting. She has received dozens of awards, held numerous solo exhibitions, and her works are held by museums, galleries, and private collectors." data-zh="赵坤的作品多以动物为题材，运用诸多技法综合各种泥料，展现出自然、纯真、质朴等多样化的艺术形象和大写意的艺术风格，作品获奖数十项，受邀多次举办个展，作品被许多博物馆、美术馆和私人收藏。">
            Her works mostly take animals as their subject, combining a wide range of clay bodies and techniques to render natural, innocent, and earthy forms in the freehand spirit of Chinese xieyi painting. She has received dozens of awards, held numerous solo exhibitions, and her works are held by museums, galleries, and private collectors.
          </p>
        </div>

        <!-- Solo Exhibitions -->
        <section class="cv-section">
          <h2 data-en="Solo Exhibitions" data-zh="个展">Solo Exhibitions</h2>
          <div class="timeline-list">
            {soloExhibitions.map(item => (
              <div class="timeline-item">
                <span class="timeline-year">{item.year}</span>
                <p class="timeline-desc" data-en={item.en} data-zh={item.zh}>{item.en}</p>
              </div>
            ))}
          </div>
        </section>

        <!-- Group Exhibitions -->
        <section class="cv-section">
          <h2 data-en="Selected Group Exhibitions" data-zh="主要群展">Selected Group Exhibitions</h2>
          <div class="timeline-list">
            {groupExhibitions.map(item => (
              <div class="timeline-item">
                <span class="timeline-year">{item.year}</span>
                <p class="timeline-desc" data-en={item.en} data-zh={item.zh}>{item.en}</p>
              </div>
            ))}
          </div>
        </section>

        <!-- Awards -->
        <section class="cv-section">
          <h2 data-en="Awards" data-zh="获奖">Awards</h2>
          <div class="timeline-list">
            {awards.map(item => (
              <div class="timeline-item">
                <span class="timeline-year">{item.year}</span>
                <p class="timeline-desc" data-en={item.en} data-zh={item.zh}>{item.en}</p>
              </div>
            ))}
          </div>
        </section>

        <!-- Collections -->
        <section class="cv-section">
          <h2 data-en="Public & Institutional Collections" data-zh="收藏">Public &amp; Institutional Collections</h2>
          <div class="timeline-list">
            {collections.map(item => (
              <div class="timeline-item">
                <span class="timeline-year">{item.year}</span>
                <p class="timeline-desc" data-en={item.en} data-zh={item.zh}>{item.en}</p>
              </div>
            ))}
          </div>
        </section>

        <!-- Publications -->
        <section class="cv-section">
          <h2 data-en="Publications & Articles" data-zh="出版与发表">Publications &amp; Articles</h2>
          <div class="timeline-list">
            {publications.map(item => (
              <div class="timeline-item">
                <span class="timeline-year">{item.year}</span>
                <p class="timeline-desc" data-en={item.en} data-zh={item.zh}>{item.en}</p>
              </div>
            ))}
          </div>
        </section>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .bio-layout {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: var(--space-xl);
    align-items: start;
  }

  .bio-portrait {
    position: sticky;
    top: calc(var(--header-height) + var(--space-md));
  }

  .bio-portrait img {
    width: 100%;
    height: auto;
    display: block;
    background-color: var(--color-bg-alt);
  }

  .page-title {
    margin-bottom: var(--space-xs);
  }

  .bio-tagline {
    color: var(--color-accent);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: var(--space-lg);
  }

  .page-title::after {
    content: '';
    display: block;
    width: 40px;
    height: 2px;
    background-color: var(--color-accent);
    margin-top: var(--space-md);
  }

  .bio-text {
    color: var(--color-text-muted);
    line-height: 1.9;
    margin-bottom: var(--space-xl);
  }

  .bio-text p {
    margin-bottom: var(--space-md);
  }

  .cv-section {
    margin-bottom: var(--space-xl);
  }

  .cv-section h2 {
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--color-border-light);
  }

  .timeline-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: var(--space-md);
    align-items: baseline;
  }

  .timeline-year {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-primary);
  }

  .timeline-desc {
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .bio-layout {
      grid-template-columns: 1fr;
    }

    .bio-portrait {
      position: static;
      max-width: 280px;
      margin: 0 auto;
    }

    .timeline-item {
      grid-template-columns: 1fr;
      gap: var(--space-xs);
    }
  }
</style>
